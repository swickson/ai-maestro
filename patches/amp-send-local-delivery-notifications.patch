@@ -31,6 +31,34 @@
 # Source helper functions
 SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
 source "${SCRIPT_DIR}/amp-helper.sh"
+
+# Send tmux push notification for local filesystem deliveries
+# This mimics what the AI Maestro server does for routed messages
+_notify_local_recipient() {
+    local recipient_name="$1"
+    local sender_addr="$2"
+    local subject="$3"
+    local priority="${4:-normal}"
+
+    # Find the recipient's tmux session
+    local session_name=""
+    # Try exact match first, then prefix match
+    if tmux has-session -t "$recipient_name" 2>/dev/null; then
+        session_name="$recipient_name"
+    fi
+
+    if [ -n "$session_name" ]; then
+        local prefix=""
+        case "$priority" in
+            urgent) prefix="🔴 [URGENT] " ;;
+            high)   prefix="🟠 [HIGH] " ;;
+            *)      prefix="" ;;
+        esac
+        local notif="${prefix}[MESSAGE] From: ${sender_addr} - ${subject} - check your inbox"
+        # Send as a tmux display-message (non-intrusive, doesn't inject into stdin)
+        tmux display-message -t "$session_name" "$notif" 2>/dev/null || true
+    fi
+}
 
 # Parse arguments
 RECIPIENT=""
